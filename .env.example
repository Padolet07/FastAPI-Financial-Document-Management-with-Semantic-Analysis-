APP_NAME="Financial Document Management System"
ENVIRONMENT=dev
APP_DEBUG=true
DATABASE_URL=sqlite:///./financial_docs.db
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
UPLOAD_DIR=storage/documents

# Dev default uses deterministic local hash embeddings and SQL storage.
VECTOR_BACKEND=sql
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Production options.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=financial_documents
OPENAI_API_KEY=
CHUNK_SIZE=900
CHUNK_OVERLAP=150
